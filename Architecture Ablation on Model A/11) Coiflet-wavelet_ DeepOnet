# ---------------------------------------------------------------------------
# Fixed 2D Coiflet wavelet basis (coarse-to-fine ordered)
# ---------------------------------------------------------------------------
def build_2d_coiflet_basis(res, wavelet_name="coif2", max_level=None):
    """
    Builds a FIXED, orthonormal-ish 2D wavelet basis using PyWavelets'
    actual Coiflet filter banks (smooth, more vanishing moments than Haar,
    no blocky artifacts). We construct the basis by taking the full 2D
    discrete wavelet transform (DWT) decomposition structure and building
    the corresponding synthesis matrix: applying pywt.waverec2 to each unit
    basis vector in coefficient space gives us that vector's spatial-domain
    basis function, ensured to be properly multi-resolution (coarse
    approximation coefficients first, then progressively finer detail
    coefficients), unlike arbitrary column-index truncation.
    """
    dummy = np.zeros((res, res))
    coeffs = pywt.wavedec2(dummy, wavelet_name, mode="periodization", level=max_level)
    coeff_arr, coeff_slices = pywt.coeffs_to_array(coeffs)
    n_total = coeff_arr.size
    flat_shape = coeff_arr.shape

    basis_vectors = []
    approx_size = coeffs[0].size

    idx_order = list(range(approx_size)) + list(range(approx_size, n_total))
    for flat_idx in idx_order:
        unit_flat = np.zeros(n_total)
        unit_flat[flat_idx] = 1.0
        unit_arr = unit_flat.reshape(flat_shape)
        unit_coeffs = pywt.array_to_coeffs(unit_arr, coeff_slices, output_format="wavedec2")
        recon = pywt.waverec2(unit_coeffs, wavelet_name, mode="periodization")
        recon = recon[:res, :res]
        basis_vectors.append(recon.flatten())

    basis = np.stack(basis_vectors, axis=1)  # (res*res, n_total)
    norms = np.linalg.norm(basis, axis=0, keepdims=True)
    norms[norms == 0] = 1.0
    basis = basis / norms
    return torch.tensor(basis, dtype=torch.float32), approx_size

N_WAVELET_MODES = 512  # retained modes, coarse-to-fine ordered
