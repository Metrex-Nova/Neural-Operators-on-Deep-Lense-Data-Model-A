# Model: Coiflet-DeepONet
# ---------------------------------------------------------------------------
class ConvBranch(nn.Module):
    def __init__(self, out_dim=128):
        super().__init__()
        self.net = nn.Sequential(
            nn.Conv2d(1, 32, 3, stride=2, padding=1), nn.GELU(),
            nn.Conv2d(32, 64, 3, stride=2, padding=1), nn.GELU(),
            nn.Conv2d(64, 128, 3, stride=2, padding=1), nn.GELU(),
            nn.AdaptiveAvgPool2d(4),
        )
        self.fc = nn.Sequential(nn.Linear(128 * 4 * 4, 256), nn.GELU(), nn.Linear(256, out_dim))

    def forward(self, x):
        h = self.net(x).flatten(1)
        return self.fc(h)


class SingleDeepONet(nn.Module):
    """Standard learned branch+trunk pair for lens_light (no wavelet-decomposable
    ground truth available for this unsupervised residual channel)."""
    def __init__(self, res=64, p=128, branch_hidden=256, trunk_hidden=128):
        super().__init__()
        n_sensors = res * res
        self.p = p
        self.branch = nn.Sequential(
            nn.Linear(n_sensors, branch_hidden), nn.GELU(),
            nn.Linear(branch_hidden, branch_hidden), nn.GELU(),
            nn.Linear(branch_hidden, p)
        )
        self.trunk = nn.Sequential(
            nn.Linear(2, trunk_hidden), nn.GELU(),
            nn.Linear(trunk_hidden, trunk_hidden), nn.GELU(),
            nn.Linear(trunk_hidden, p), nn.GELU()
        )
        self.bias = nn.Parameter(torch.zeros(1))

    def forward(self, x_flat, coords):
        branch_out = self.branch(x_flat)
        trunk_out = self.trunk(coords)
        return torch.einsum("bp,np->bn", branch_out, trunk_out) + self.bias


class CoifletDeepONet(nn.Module):
    """
    Coiflet-DeepONet: trunk is a FIXED, coarse-to-fine-ordered 2D Coiflet
    wavelet basis (via PyWavelets), instead of Haar's blocky basis, an
    arbitrary learned coordinate-MLP, or a data-driven SVD basis. Coiflets
    have smooth, more-vanishing-moment wavelets, producing smooth
    reconstructions rather than blocky artifacts, while still being
    multi-resolution (able to represent both smooth macro-lens structure
    and localized subhalo-scale detail).
    """
    def __init__(self, res, wavelet_basis, n_modes, branch_dim=128):
        super().__init__()
        self.res = res
        self.n_modes = n_modes
        self.register_buffer("wavelet_basis", wavelet_basis)  # (res*res, n_modes), FIXED

        self.branch = ConvBranch(out_dim=branch_dim)
        self.coeff_head = nn.Sequential(
            nn.Linear(branch_dim, branch_dim), nn.GELU(),
            nn.Linear(branch_dim, 2 * n_modes)
        )

        self.lens_light_net = SingleDeepONet(res=res, p=128)
        ys, xs = torch.meshgrid(torch.linspace(-1, 1, res), torch.linspace(-1, 1, res), indexing="ij")
        coords = torch.stack([ys.flatten(), xs.flatten()], dim=-1)
        self.register_buffer("coords", coords)

    def forward(self, x):
        B, C, H, W = x.shape

        branch_feat = self.branch(x)
        coeffs = self.coeff_head(branch_feat)
        coeffs_x, coeffs_y = coeffs[:, :self.n_modes], coeffs[:, self.n_modes:]

        alpha_x_flat = coeffs_x @ self.wavelet_basis.T
        alpha_y_flat = coeffs_y @ self.wavelet_basis.T
        alpha_x = alpha_x_flat.view(B, H, W)
        alpha_y = alpha_y_flat.view(B, H, W)

        x_flat = x.reshape(B, -1)
        lens_light_flat = self.lens_light_net(x_flat, self.coords)
        lens_light = lens_light_flat.view(B, H, W)

        out = torch.stack([alpha_x, alpha_y, lens_light], dim=1)
        return out


class LearnablePSFBlur(nn.Module):
    def __init__(self, kernel_size=9, init_sigma=1.0):
        super().__init__()
        self.kernel_size = kernel_size
        self.log_sigma = nn.Parameter(torch.tensor(float(np.log(init_sigma))))

    def forward(self, x):
        sigma = torch.exp(self.log_sigma).clamp(min=0.05, max=5.0)
        k = self.kernel_size
        coords = torch.arange(k, device=x.device, dtype=x.dtype) - (k - 1) / 2
        g = torch.exp(-(coords ** 2) / (2 * sigma ** 2))
        g = g / g.sum()
        kernel_2d = (g[:, None] * g[None, :]).view(1, 1, k, k)
        return F.conv2d(x.unsqueeze(1), kernel_2d, padding=k // 2).squeeze(1)


model = CoifletDeepONet(RES, wavelet_basis, n_modes=N_WAVELET_MODES, branch_dim=128).to(device)
psf_blur = LearnablePSFBlur(kernel_size=9, init_sigma=1.0).to(device)
